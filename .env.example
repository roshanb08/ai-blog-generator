# ── NewsAPI ──────────────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── LLM Provider selection ────────────────────────────────────────────────────
# Choose: 'openwebui' or 'openrouter'
LLM_PROVIDER=openwebui

# ── OpenWebUI (used when LLM_PROVIDER=openwebui) ──────────────────────────────
# Base URL of your OpenWebUI instance (no trailing slash)
OPENWEBUI_BASE_URL=https://your-openwebui-instance.com
OPENWEBUI_API_KEY=your_openwebui_api_key_here
OPENWEBUI_MODEL=gpt-4o

# ── OpenRouter (used when LLM_PROVIDER=openrouter) ────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Any model available on OpenRouter — see https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o
# Optional: helps OpenRouter attribute traffic; set to your site URL
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_SITE_NAME=AI Blog Generator

# ── Shared LLM behaviour ──────────────────────────────────────────────────────
# Per-attempt timeout for the LLM HTTP call (seconds)
LLM_TIMEOUT=90
# Sampling temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7
# Max tokens in the LLM response — free models typically use 600-900 for a full blog
LLM_MAX_TOKENS=2048
# Total wall-clock budget for the entire /generate-blog request (seconds)
REQUEST_TIMEOUT=120

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
ENVIRONMENT=production

# ── Deduplication ─────────────────────────────────────────────────────────────
# Path inside the container where SQLite DB is stored (backed by a Docker volume)
DEDUP_DB_PATH=/data/dedup.db
# How similar two titles must be (0-1) to be considered duplicates
DEDUP_TITLE_SIMILARITY_THRESHOLD=0.65
# How many hours to remember seen articles before expiring them
DEDUP_TTL_HOURS=48

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
# Seconds to serve a cached response for the same category/country/limit
CACHE_TTL_SECONDS=300

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional — increases GitHub Search API rate limit from 10 to 30 req/min
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_...

# ── Tuning ────────────────────────────────────────────────────────────────────
# Max articles to fetch from NewsAPI per request (before dedup)
MAX_NEWS_FETCH=20
